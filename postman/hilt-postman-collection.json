    {
      "name": "Hilt Pay API",
      "item": [
        {
          "name": "Agent bootstrap",
          "description": "Agent-first Hilt Pay API setup: create a sandbox setup intent, submit a manifest, receive a pricing recommendation, and wait for owner approval before live key issuance.",
          "item": [
            {
              "name": "Create agent setup intent",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json",
                    "type": "text"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"agent_name\": \"Acme API Builder\",\n  \"agent_platform\": \"cursor\",\n  \"requested_use_case\": \"Protect /ai/pro with Hilt Pay API\",\n  \"contact_email\": \"founder@acme.test\",\n  \"requested_permissions\": [\n    \"access:read\",\n    \"access:write\",\n    \"access:webhooks\"\n  ],\n  \"ttl_hours\": 24\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/v1/access/agent-bootstrap",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "v1",
                    "access",
                    "agent-bootstrap"
                  ]
                }
              }
            },
            {
              "name": "Submit agent setup manifest",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json",
                    "type": "text"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"setup_token\": \"{{setupToken}}\",\n  \"manifest\": {\n    \"app\": {\n      \"name\": \"Acme AI\",\n      \"external_app_id\": \"acme-ai\"\n    },\n    \"product\": {\n      \"external_product_id\": \"pro-api\",\n      \"title\": \"Pro API access\",\n      \"amount_minor_units\": 79000000,\n      \"default_rail\": \"solana_usdc\",\n      \"expected_monthly_payments\": 120,\n      \"expected_monthly_volume_usd\": 9480,\n      \"expected_monthly_webhook_events\": 500,\n      \"expected_monthly_entitlement_checks\": 12000,\n      \"billing_model\": \"recurring\",\n      \"renewal_mode\": \"solana_native_subscription\",\n      \"billing_interval_days\": 30,\n      \"cancel_at_period_end\": true\n    },\n    \"payment_protocol\": \"x402\",\n    \"settlement_rail\": \"solana_usdc\",\n    \"protected_resource\": {\n      \"url\": \"https://api.acme.test/ai/pro\",\n      \"method\": \"POST\",\n      \"customer_identity\": \"external_customer_id\"\n    },\n    \"webhook\": {\n      \"url\": \"https://api.acme.test/webhooks/hilt\",\n      \"subscribed_events\": [\n        \"access.entitlement.activated\",\n        \"payment.confirmed\"\n      ]\n    }\n  }\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/v1/access/agent-bootstrap/{{setupIntentId}}/manifest",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "v1",
                    "access",
                    "agent-bootstrap",
                    "{{setupIntentId}}",
                    "manifest"
                  ]
                }
              }
            },
            {
              "name": "Get agent setup status",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json",
                    "type": "text"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"setup_token\": \"{{setupToken}}\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/v1/access/agent-bootstrap/{{setupIntentId}}/status",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "v1",
                    "access",
                    "agent-bootstrap",
                    "{{setupIntentId}}",
                    "status"
                  ]
                }
              }
            },
            {
              "name": "Owner approves agent setup",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{bearerToken}}",
                    "type": "text"
                  },
                  {
                    "key": "Content-Type",
                    "value": "application/json",
                    "type": "text"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"setup_token\": \"{{setupToken}}\",\n  \"approved_permissions\": [\n    \"access:read\",\n    \"access:write\",\n    \"access:webhooks\"\n  ],\n  \"issue_live_key\": true,\n  \"live_key_name\": \"Acme AI Hilt Pay API key\",\n  \"confirm_owner_approval\": true\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/v1/access/agent-bootstrap/{{setupIntentId}}/approve",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "v1",
                    "access",
                    "agent-bootstrap",
                    "{{setupIntentId}}",
                    "approve"
                  ]
                }
              }
            }
          ]
        },
